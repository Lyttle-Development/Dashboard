{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "npm run build && next start -p 3000",
    "lint": "next lint",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:dangerously-db-push": "prisma db push",
    "prisma:migrate": "prisma migrate dev --name merge-upstream",
    "prisma:deploy": "prisma migrate deploy",
    "docker:setup": "npm run build",
    "docker:build": "docker build -t community-v3-dashboard .",
    "update": "npm update --save && npx npm-check-updates -u && npm install"
  },
  "volta": {
    "node": "22.19.0"
  },
  "engines": {
    "node": "22.19.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.0.1",
    "@fortawesome/free-solid-svg-icons": "^7.0.1",
    "@fortawesome/react-fontawesome": "^3.0.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.15.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@sparticuz/chromium": "^138.0.2",
    "@types/next-auth": "^3.15.0",
    "classnames": "^2.5.1",
    "next": "^15.5.2",
    "next-auth": "^4.24.11",
    "next-seo": "^6.8.0",
    "pg": "^8.16.3",
    "playwright-core": "^1.55.0",
    "prettier": "^3.6.2",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.92.0",
    "soap": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.2",
    "prisma": "^6.15.0",
    "typescript": "^5.9.2"
  }
}
