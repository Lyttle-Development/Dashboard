{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "npm run build && next start -p 3000",
    "lint": "next lint",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:dangerously-db-push": "prisma db push",
    "prisma:migrate": "prisma migrate dev --name merge-upstream",
    "prisma:deploy": "prisma migrate deploy",
    "docker:setup": "npm run prisma:generate && npm run build",
    "docker:build": "docker build -t community-v3-dashboard .",
    "update": "npm update --save && npx npm-check-updates -u && npm install"
  },
  "volta": {
    "node": "24.15.0"
  },
  "engines": {
    "node": "24.15.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "@sparticuz/chromium": "^148.0.0",
    "@types/next-auth": "^3.15.0",
    "classnames": "^2.5.1",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "next-seo": "^7.2.0",
    "pg": "^8.20.0",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0",
    "soap": "^1.9.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "prisma": "^7.8.0",
    "typescript": "6.0.3"
  }
}
